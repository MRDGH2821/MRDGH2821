{
  "overrides": [
    {
      "files": ["*.jsonc", "*.json"],
      "options": {
        "parser": "json",
        "trailingComma": "none"
      }
    },
    {
      "files": ["*.sh", "**/.envrc"],
      "options": {
        "parser": "sh",
        "spaceRedirects": false
      }
    },
    {
      "files": [".editorconfig"],
      "options": {
        "parser": "ini"
      }
    }
  ],
  "plugins": [
    "prettier-plugin-toml",
    "@prettier/plugin-xml",
    "prettier-plugin-sh",
    "prettier-plugin-ini"
  ],
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false
}
